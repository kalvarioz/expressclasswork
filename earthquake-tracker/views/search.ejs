<%- include('partials/header', { title: 'Search' }) %>
<%- include('partials/nav') %>

<main class="main">
    <h1 class="page-title">Search Earthquakes</h1>
    <p class="page-desc">Filter by magnitude, date range, and result limit.</p>

  <section class="form-section">
    <form action="/results" method="GET" class="search-form">
      <div class="form-grid">

        <div class="form-group">
          <label class="form-label" for="minmagnitude">Minimum Magnitude</label>
          <select name="minmagnitude" id="minmagnitude" class="form-select">
            <option value="1">M1.0+</option>
            <option value="2" selected>M2.0+</option>
            <option value="2.5">M2.5+</option>
            <option value="4">M4.0+</option>
            <option value="5">M5.0+</option>
            <option value="6">M6.0+</option>
            <option value="7">M7.0+</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="maxmagnitude">Maximum Magnitude</label>
          <select name="maxmagnitude" id="maxmagnitude" class="form-select">
            <option value="10" selected>Any</option>
            <option value="3">Up to M3</option>
            <option value="4">Up to M4</option>
            <option value="5">Up to M5</option>
            <option value="6">Up to M6</option>
            <option value="7">Up to M7</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="starttime">Start Date</label>
          <input type="date" name="starttime" id="starttime" class="form-input"
            value="<%= new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0] %>" />
        </div>

        <div class="form-group">
          <label class="form-label" for="endtime">End Date</label>
          <input type="date" name="endtime" id="endtime" class="form-input"
            value="<%= new Date().toISOString().split('T')[0] %>" />
        </div>

        <div class="form-group">
          <label class="form-label" for="limit">Result Limit</label>
          <select name="limit" id="limit" class="form-select">
            <option value="10">10 results</option>
            <option value="25" selected>25 results</option>
            <option value="50">50 results</option>
            <option value="100">100 results</option>
          </select>
        </div>

      </div>
      <button type="submit" class="btn btn-primary btn-large">Search!</button>
    </form>
  </section>
</main>

<%- include('partials/footer') %>
</body>
</html>
