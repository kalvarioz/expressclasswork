<%- include('partials/header') %>

<section class="hero">
  <h1 class="hero-title">CalvMovies</h1>
  <p class="hero-sub"><%= totalMovies %> movies total. Browse and Search Movies! </p>
  <a href="/movies" class="btn-primary">Browse Library</a>
</section>

<section class="featured-section">
  <h2 class="section-heading">Featured</h2>
  <div class="card-grid">
    <% featured.forEach(movie => { %>
      <%- include('partials/movie-card', { movie }) %>
    <% }) %>
  </div>
</section>

<section class="search-cta">
  <p>Looking for something specific?</p>
  <a href="/search" class="btn-secondary">Search by title or genre</a>
</section>

<%- include('partials/footer') %>