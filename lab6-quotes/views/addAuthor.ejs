<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Author</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="bg-light">
    <%-include ('partials/head')%>
    <div class="container py-4" style="max-width: 600px;">
        <nav class="mb-3">
            <a href="/" class="btn btn-outline-secondary btn-sm">Back to Search</a>
        </nav>
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">Add New Author</h4>
            </div>
            <div class="card-body">
                <form action="/addAuthor" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">First Name</label>
                        <input type="text" name="firstName" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Last Name</label>
                        <input type="text" name="lastName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sex</label>
                        <div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="sex" id="sexFemale" value="F" required>
                                <label class="form-check-label" for="sexFemale">Female</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="sex" id="sexMale" value="M">
                                <label class="form-check-label" for="sexMale">Male</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Date of Birth</label>
                        <input type="date" name="dob" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Date of Death <span class="text-muted fw-normal">(leave blank if living)</span></label>
                        <input type="date" name="dod" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Biography</label>
                        <textarea name="biography" class="form-control" rows="4" placeholder="Write a short biography..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Picture URL</label>
                        <textarea name="portrait" class="form-control" rows="2" placeholder="https://..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Add Author</button>
                </form>
            </div>
        </div>
    </div>

    <%-include ('partials/footer')%>
</body>

</html>