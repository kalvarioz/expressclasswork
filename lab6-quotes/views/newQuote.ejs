<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Quote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="bg-light">
    <%-include ('partials/head')%>
    <div class="container py-4" style="max-width: 600px;">
        <nav class="mb-3">
            <a href="/" class="btn btn-outline-secondary btn-sm">Back to Search</a>
        </nav>
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">Add New Quote</h4>
            </div>
            <div class="card-body">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <form action="/newQuote" method="POST" id="quoteForm">
                    <div class="mb-3">
                        <label class="form-label">Quote</label>
                        <textarea name="quote" id="quoteText" class="form-control"
                            required><% if (typeof formData !== 'undefined') { %><%= formData.quote %><% } %></textarea>
                        <div id="quoteError" class="text-danger mt-1" style="display:none;">
                            Quote must be at least 5 characters.
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Author</label>
                        <select name="authorId" class="form-select" required>
                            <option value="" disabled selected>Select an author</option>
                            <% for (let a of authors) { %>
                                <option value="<%= a.authorId %>">
                                    <%= a.firstName %> <%= a.lastName %>
                                </option>
                            <% } %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select name="category" class="form-select" required>
                            <option value="" disabled selected>Select a category</option>
                            <% for (let c of categories) { %>
                                <option value="<%= c.category %>"><%= c.category %></option>
                            <% } %>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Add Quote</button>
                </form>
            </div>
        </div>
    </div>
    <%-include ('partials/footer')%>
    <script src="js/newQuote.js"></script>
</body>
</html>
