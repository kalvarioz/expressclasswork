<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Solar System - NASA Picture of the Day</title>
</head>
<body>
    <h1 class="bg-info text-white text-center p-3 m-0">The Solar System</h1>

    <%- include('partials/nav') %>

    <div class="container mt-5">
        <h2 class="text-white text-center display-4 mb-2"> NASA Picture of the Day</h2>
        <p class="text-info text-center mb-4"><%= pod.date %></p>

        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card bg-dark text-white border-info">
                    <div class="card-header bg-info text-dark fw-bold fs-5">
                        <%= pod.title %>
                    </div>

                    <% if (pod.media_type === 'video') { %>
                        <div class="ratio ratio-16x9">
                            <iframe src="<%= pod.url %>" allowfullscreen></iframe>
                        </div>
                    <% } else { %>
                        <img src="<%= pod.hdurl || pod.url %>" class="card-img-top" alt="<%= pod.title %>"
                            style="max-height: 550px; object-fit: contain; background: black;">
                    <% } %>

                    <div class="card-body">
                        <p class="card-text"><%= pod.explanation %></p>
                        <% if (pod.copyright) { %>
                            <p class="text-muted small">© <%= pod.copyright %></p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>