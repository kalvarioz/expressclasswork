<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <link rel="stylesheet" href="/styles.css">
    <title>Lab 5: Solar System</title>
</head>

<body>
    <%-include ('partials/head')%>
        <h1 class="bg-info text-white p-3">The Solar System</h1>

        <body>
            <div class="row justify-content-center mt-5">
                <div class="col-12">
                    <div class="nasaPodInfo">
                        <a href="/nasa-pod" class="btn btn-outline-info w-100 py-3 fs-5">View todays picture of the
                            day!</a>
                    </div>
                    <div class="row row-cols-2 row-cols-md-4 g-3">
                        <% ['Mercury', 'Venus' , 'Earth' , 'Mars' , 'Jupiter' , 'Saturn' , 'Uranus' , 'Neptune'
                            ].forEach(p=> { %>
                            <div class="col">
                                <a href="/planetInfo?planet=<%= p %>" class="btn btn-outline-info w-100 py-3 fs-5">
                                    <%= p %>
                                </a>
                            </div>
                            <% }) %>
                    </div>
                    <div class="cometInformation">
                        <a href="/comets" class="btn btn-outline-info w-100 py-3 fs-5">Comets</a>
                    </div>
                </div>
                <div class="asteroidInformation">
                    <a href="/asteroids" class="btn btn-outline-info w-100 py-3 fs-5">Astroids</a>
                </div>
            </div>
        </body>
        <% if (pixabayImage) { %>
            <div class="row justify-content-center mt-4">
                <div class="col-md-8">
                    <div class="card bg-dark text-white border-info">
                        <div class="card-header bg-info text-dark fw-bold">
                            Random Space Image (via Pixabay)
                        </div>
                        <img src="<%= pixabayImage %>" class="card-img-top" alt="Random space image"
                            style="max-height: 750px; object-fit: cover;">
                    </div>
                </div>
            </div>
            <% } %>
                <%-include ('partials/footer')%>

</body>

</html>